      { "file": "api.js" },
      { "file": "card.js" },
      { "file": "settings.js" },
      { "file": "sync.js" },
      { "file": "panel.js" },
      { "file": "styles.js" },
      { "file": "capture.js" },
      { "file": "bridge.js" },
      { "file": "main.js" }
    ]
  }
}
