{
  "manifest_version": 1,
  "name": "LyricLens",
  "version": "0.1.0",
  "author": "Yoru",
  "description": "AI lyrics learning assistant",
  "betterncm_version": ">=0.2.5",
  "ncm3-compatible": true,
  "injects": {
    "Main": [
      { "file": "diagnostics.js" },
      { "file": "utils.js" },
