{
  "manifest_version": 1,
  "name": "LyricLens",
  "slug": "yoru.lyriclens",
  "version": "0.1.0",
  "author": "Yoru",
  "author_links": ["https://github.com/yoruuuchan"],
  "description": "AI lyrics learning assistant — turns lyrics into language-learning cards while you listen.",
  "preview": "preview.png",
  "type": "extension",
  "betterncm_version": ">=1.0.0",
  "ncm3-compatible": true,
  "injects": {
    "Main": [
      { "file": "diagnostics.js" },
      { "file": "utils.js" },
      { "file": "cache.js" },
      { "file": "updater.js" },
      { "file": "detect.js" },
      { "file": "lyrics.js" },
      { "file": "api.js" },
      { "file": "card.js" },
      { "file": "settings.js" },
      { "file": "sync.js" },
      { "file": "panel.js" },
      { "file": "styles.js" },
      { "file": "capture.js" },
      { "file": "bridge.js" },
      { "file": "ncmLyricApi.js" },
      { "file": "main.js" }
    ]
  }
}
